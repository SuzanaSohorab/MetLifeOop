<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #4A4A4A;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.metlife.nisha.CustomerPayPremiumController">
    <children>
        <Pane layoutX="200.0" layoutY="50.0" prefHeight="600.0" prefWidth="600.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8;">
            <children>
                <Label layoutX="30.0" layoutY="20.0" text="Pay Premium">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <Separator layoutX="30.0" layoutY="60.0" prefWidth="540.0" />

                <VBox layoutX="30.0" layoutY="80.0" prefWidth="540.0" spacing="20.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="1. Select Invoice to Pay" />
                        <TableView fx:id="invoiceTable" prefHeight="150.0" />

                        <Separator />

                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="2. Select Payment Method" />

                        <VBox spacing="15.0" style="-fx-background-color: #F9F9F9; -fx-padding: 20; -fx-border-color: #E0E0E0; -fx-border-radius: 5;">
                            <children>
                                <RadioButton fx:id="cardRadio" style="-fx-font-size: 14px;" text="Credit / Debit Card (Visa, MasterCard, Amex)">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="paymentToggleGroup" />
                                    </toggleGroup>
                                </RadioButton>
                                <RadioButton fx:id="bkashRadio" style="-fx-font-size: 14px;" text="bKash (Mobile Wallet)" toggleGroup="$paymentToggleGroup" />
                                <RadioButton fx:id="bankRadio" style="-fx-font-size: 14px;" text="Bank Transfer" toggleGroup="$paymentToggleGroup" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <Button layoutX="30.0" layoutY="530.0" mnemonicParsing="false" onAction="#proceedToPayment" prefHeight="45.0" prefWidth="440.0" style="-fx-background-color: #FF6F00; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" text="Proceed to Payment" />
                <Button layoutX="490.0" layoutY="530.0" mnemonicParsing="false" onAction="#goBack" prefHeight="45.0" prefWidth="80.0" text="Back" />
            </children>
        </Pane>
    </children>
</AnchorPane>
