<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #4D4D4D;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.metlife.nisha.AgentDashboardController">
    <children>
        <Pane layoutX="300.0" layoutY="50.0" prefHeight="600.0" prefWidth="400.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 5;">
            <children>
                <Label layoutX="125.0" layoutY="20.0" text="Agent Dashboard">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Label layoutX="30.0" layoutY="60.0" text="Welcome, Agent" />
                <Label layoutX="30.0" layoutY="85.0" text="Select an action:" />
                <VBox layoutX="30.0" layoutY="110.0" prefHeight="400.0" prefWidth="340.0" spacing="12.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#goToPendingTasks" prefHeight="35.0" prefWidth="340.0" text="Pending Tasks" />
                        <Button mnemonicParsing="false" onAction="#goToCustomerSearch" prefHeight="35.0" prefWidth="340.0" text="Customer Search" />
                        <Button mnemonicParsing="false" onAction="#goToAgentTools" prefHeight="35.0" prefWidth="340.0" text="Agent Tools" />
                    </children>
                </VBox>
                <Button layoutX="165.0" layoutY="545.0" mnemonicParsing="false" onAction="#logout" prefHeight="30.0" prefWidth="70.0" text="Logout" />
            </children>
        </Pane>
    </children>
</AnchorPane>
