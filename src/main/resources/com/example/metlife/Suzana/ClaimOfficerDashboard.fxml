<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="ClaimDashboardPane" prefHeight="588.0" prefWidth="799.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.metlife.Suzana.ClaimOfficerDashboard">

    <children>

        <!-- 🔹 TOP MENU -->
        <MenuBar fx:id="menu" layoutX="0.0" layoutY="0.0" prefHeight="26.0" prefWidth="799.0">
            <menus>
                <Menu text="File">
                    <items>
                        <MenuItem text="Close" />
                    </items>
                </Menu>
                <Menu text="Edit">
                    <items>
                        <MenuItem text="Delete" />
                    </items>
                </Menu>
                <Menu text="Help">
                    <items>
                        <MenuItem text="About" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <!-- 🔹 TITLE -->
        <Label layoutX="200.0" layoutY="35.0" text="Claim Officer Dashboard" />

        <!-- 🔹 LEFT SIDE BUTTONS -->
        <Button layoutX="20.0" layoutY="80.0" onAction="#allClaimButtonOA" prefWidth="100.0" text="All Claim" />

        <Button layoutX="20.0" layoutY="120.0" onAction="#pendingClaimButtonOA" text="Pending Claim" />

        <Button layoutX="20.0" layoutY="160.0" onAction="#requestClaimOA" text="Request Claim" />

        <Button layoutX="20.0" layoutY="200.0" onAction="#passFinanceOA" prefHeight="26.0" prefWidth="108.0" text="Pass Finance" />

        <Button layoutX="20.0" layoutY="281.0" onAction="#handleLogout" text="Logout" />

        <!-- 🔹 TABLE AREA -->
        <AnchorPane layoutX="140.0" layoutY="70.0" prefHeight="300.0" prefWidth="440.0">

            <children>

                <TableView fx:id="ClaimTable" layoutX="0.0" layoutY="0.0" prefHeight="315.0" prefWidth="626.0">

                    <columns>
                        <TableColumn fx:id="ClaimIdCol" prefWidth="80.0" text="Claim ID" />
                        <TableColumn fx:id="PolicyIdCol" prefWidth="80.0" text="Policy ID" />
                        <TableColumn fx:id="ReasonCol" prefWidth="100.0" text="Reason" />
                        <TableColumn fx:id="StatusCol" prefWidth="80.0" text="Status" />
                        <TableColumn fx:id="ClaimAmountCol" prefWidth="100.0" text="Claim Amount" />
                    </columns>

                </TableView>

            </children>
        </AnchorPane>
      <Button layoutX="20.0" layoutY="239.0" onAction="#generateReportOA" text="Gerenaret Report" />

    </children>
</AnchorPane>
